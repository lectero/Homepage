---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, translatePath, alternateLocale, defaultLocale } from '../i18n/utils';
import { getStrings } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const t = getStrings(locale);
const { title, description = t.meta.siteDescription } = Astro.props;

const currentPath = Astro.url.pathname;
const otherLocale = alternateLocale(locale);
const altPath = translatePath(currentPath, otherLocale);
const sitePath = translatePath(currentPath, defaultLocale);

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="alternate" hreflang="sv" href={`${siteOrigin}${translatePath(currentPath, 'sv')}`} />
    <link rel="alternate" hreflang="en" href={`${siteOrigin}${translatePath(currentPath, 'en')}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteOrigin}${sitePath}`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Lectero</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:text-primary focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:outline-2 focus:outline-accent"
    >
      {t.nav.skipToMain}
    </a>
    <Header locale={locale} altPath={altPath} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
