---
import { getStrings, type Locale } from '../i18n/strings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
const c = t.mbot.comparison;
---

<section class="max-w-6xl mx-auto px-6 py-20" id="mbot-comparison">
  <h2 class="text-3xl font-bold text-primary mb-4 text-center">{c.heading}</h2>
  <p class="text-center text-gray-600 max-w-3xl mx-auto mb-6">{c.lead}</p>
  <p class="text-center text-sm text-gray-500 max-w-3xl mx-auto mb-12 italic">
    {c.framingNote}
  </p>

  <!-- Desktop: traditional table -->
  <div class="hidden lg:block overflow-x-auto rounded-2xl border border-gray-100 bg-white">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface text-left">
          <th class="px-5 py-4 font-semibold text-primary w-[22%]">
            {locale === 'sv' ? 'Dimension' : 'Dimension'}
          </th>
          <th class="px-5 py-4 font-semibold text-accent bg-accent/5 w-[28%]">
            {c.columnMbot}
          </th>
          <th class="px-5 py-4 font-semibold text-gray-700 w-[28%]">
            {c.columnGeneric}
          </th>
          <th class="px-5 py-4 font-semibold text-gray-700 w-[22%]">
            {c.columnManual}
          </th>
        </tr>
      </thead>
      <tbody>
        {c.rows.map((row) => (
          <tr class="border-t border-gray-100 align-top">
            <th scope="row" class="px-5 py-4 text-left font-semibold text-primary">
              {row.dimension}
            </th>
            <td class="px-5 py-4 text-gray-800 bg-accent/5 leading-relaxed">{row.mbot}</td>
            <td class="px-5 py-4 text-gray-700 leading-relaxed">{row.generic}</td>
            <td class="px-5 py-4 text-gray-700 leading-relaxed">{row.manual}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Mobile/tablet: stack as cards -->
  <ol class="lg:hidden space-y-5">
    {c.rows.map((row, idx) => (
      <li class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
        <header class="bg-surface px-5 py-3 border-b border-gray-100">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide" aria-hidden="true">
            {String(idx + 1).padStart(2, '0')}
          </p>
          <h3 class="text-lg font-semibold text-primary">{row.dimension}</h3>
        </header>
        <dl class="divide-y divide-gray-100">
          <div class="px-5 py-4 bg-accent/5">
            <dt class="text-xs font-semibold uppercase tracking-wide text-accent mb-1">
              {c.columnMbot}
            </dt>
            <dd class="text-sm text-gray-800 leading-relaxed">{row.mbot}</dd>
          </div>
          <div class="px-5 py-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1">
              {c.columnGeneric}
            </dt>
            <dd class="text-sm text-gray-700 leading-relaxed">{row.generic}</dd>
          </div>
          <div class="px-5 py-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1">
              {c.columnManual}
            </dt>
            <dd class="text-sm text-gray-700 leading-relaxed">{row.manual}</dd>
          </div>
        </dl>
      </li>
    ))}
  </ol>

  <p class="text-xs text-gray-500 text-center mt-8 max-w-3xl mx-auto leading-relaxed">
    {c.footnote}
  </p>
  <p class="text-xs text-gray-500 text-center mt-2">
    <a href="/products/mbot/whitepaper/" class="text-accent hover:underline">{c.evidenceLink}</a>
  </p>
</section>
