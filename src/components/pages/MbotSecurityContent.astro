---
import Hero from '../Hero.astro';
import { getStrings, type Locale } from '../../i18n/strings';
import { localizePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
---

<Hero title={t.mbotSecurity.heroTitle} subtitle={t.mbotSecurity.heroSubtitle} />

<section class="max-w-3xl mx-auto px-6 pt-12 pb-6">
  <div class="bg-accent/5 border-l-4 border-accent rounded-r-lg px-6 py-4">
    <p class="text-sm text-gray-700 leading-relaxed">{t.mbotSecurity.audienceNote}</p>
  </div>
</section>

<section class="max-w-5xl mx-auto px-6 py-12">
  <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.modelHeading}</h2>
  <p class="text-gray-600 leading-relaxed mb-8 max-w-3xl">{t.mbotSecurity.modelLead}</p>
  <ol class="grid md:grid-cols-2 gap-6">
    {t.mbotSecurity.modelBoundaries.map((b, idx) => (
      <li class="bg-white rounded-xl p-6 border border-gray-100">
        <p class="text-xs font-medium text-accent uppercase tracking-wide mb-2" aria-hidden="true">
          {String(idx + 1).padStart(2, '0')}
        </p>
        <h3 class="font-semibold text-primary mb-2">{b.title}</h3>
        <p class="text-sm text-gray-600 leading-relaxed">{b.text}</p>
      </li>
    ))}
  </ol>
</section>

<section class="bg-surface py-16">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.flowHeading}</h2>
    <p class="text-gray-600 leading-relaxed mb-8 max-w-3xl">{t.mbotSecurity.flowLead}</p>
    <ol class="space-y-3">
      {t.mbotSecurity.flowSteps.map((s) => (
        <li class="bg-white rounded-lg p-4 border border-gray-100 flex gap-4">
          <p class="font-mono text-sm text-accent shrink-0 w-32 sm:w-40">{s.step}</p>
          <p class="text-sm text-gray-700 leading-relaxed">{s.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<section class="max-w-5xl mx-auto px-6 py-16">
  <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.storageHeading}</h2>
  <p class="text-gray-600 leading-relaxed mb-8 max-w-3xl">{t.mbotSecurity.storageLead}</p>
  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl p-6 border border-gray-100">
      <h3 class="font-semibold text-primary mb-3">{t.mbotSecurity.storageOpsTitle}</h3>
      <ul class="space-y-2 text-sm text-gray-700">
        {t.mbotSecurity.storageOpsAllowed.map((line) => (
          <li class="flex gap-2">
            <span class="text-green-700 shrink-0" aria-hidden="true">✓</span>
            <code class="font-mono text-xs bg-surface rounded px-1.5 py-0.5">{line}</code>
          </li>
        ))}
      </ul>
      <h4 class="font-semibold text-primary mt-6 mb-3 text-sm uppercase tracking-wide">
        {locale === 'sv' ? 'Inte tillåtet i operativa loggar' : 'Not allowed in operational logs'}
      </h4>
      <ul class="space-y-2 text-sm text-gray-700">
        {t.mbotSecurity.storageOpsForbidden.map((line) => (
          <li class="flex gap-2">
            <span class="text-red-700 shrink-0" aria-hidden="true">✗</span>
            <span>{line}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-100">
      <h3 class="font-semibold text-primary mb-3">{t.mbotSecurity.storageEvalTitle}</h3>
      <p class="text-sm text-gray-700 leading-relaxed">{t.mbotSecurity.storageEvalBody}</p>
    </div>
  </div>
</section>

<section class="bg-surface py-16">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.retentionHeading}</h2>
    <p class="text-gray-600 leading-relaxed mb-8 max-w-3xl">{t.mbotSecurity.retentionLead}</p>
    <div class="overflow-x-auto bg-white rounded-xl border border-gray-100">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-left">
          <tr>
            <th class="px-4 py-3 font-semibold text-primary">
              {locale === 'sv' ? 'Datafält' : 'Data field'}
            </th>
            <th class="px-4 py-3 font-semibold text-primary">
              {locale === 'sv' ? 'Retention-policy' : 'Retention policy'}
            </th>
          </tr>
        </thead>
        <tbody>
          {t.mbotSecurity.retentionRows.map((row) => (
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3 align-top">
                <code class="font-mono text-xs">{row.field}</code>
              </td>
              <td class="px-4 py-3 text-gray-700 align-top">{row.rule}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="max-w-5xl mx-auto px-6 py-16">
  <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.processorsHeading}</h2>
  <p class="text-gray-600 leading-relaxed mb-8 max-w-3xl">{t.mbotSecurity.processorsLead}</p>
  <div class="grid md:grid-cols-2 gap-4">
    {t.mbotSecurity.processors.map((p) => (
      <div class="bg-white rounded-xl p-5 border border-gray-100">
        <h3 class="font-semibold text-primary">{p.name}</h3>
        <dl class="mt-3 space-y-1.5 text-sm">
          <div class="flex gap-2">
            <dt class="text-gray-500 w-24 shrink-0">
              {locale === 'sv' ? 'Roll' : 'Role'}
            </dt>
            <dd class="text-gray-700">{p.role}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-gray-500 w-24 shrink-0">
              {locale === 'sv' ? 'Region' : 'Region'}
            </dt>
            <dd class="text-gray-700">{p.region}</dd>
          </div>
          <div class="flex gap-2">
            <dt class="text-gray-500 w-24 shrink-0">
              {locale === 'sv' ? 'Grund' : 'Basis'}
            </dt>
            <dd class="text-gray-700">{p.transferBasis}</dd>
          </div>
        </dl>
      </div>
    ))}
  </div>
</section>

<section class="bg-surface py-16">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.gdprOpsHeading}</h2>
    <p class="text-gray-600 leading-relaxed mb-8 max-w-3xl">{t.mbotSecurity.gdprOpsLead}</p>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white rounded-xl p-6 border border-gray-100">
        <h3 class="font-semibold text-primary mb-3">{t.mbotSecurity.pubTitle}</h3>
        <p class="text-sm text-gray-700 leading-relaxed">{t.mbotSecurity.pubBody}</p>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-100">
        <h3 class="font-semibold text-primary mb-3">{t.mbotSecurity.dsarTitle}</h3>
        <p class="text-sm text-gray-700 leading-relaxed">{t.mbotSecurity.dsarBody}</p>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-100">
        <h3 class="font-semibold text-primary mb-3">{t.mbotSecurity.incidentTitle}</h3>
        <p class="text-sm text-gray-700 leading-relaxed">{t.mbotSecurity.incidentBody}</p>
      </div>
    </div>
  </div>
</section>

<section class="max-w-5xl mx-auto px-6 py-16">
  <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.statusHeading}</h2>
  <p class="text-gray-600 leading-relaxed mb-8 max-w-3xl">{t.mbotSecurity.statusLead}</p>
  <div class="grid md:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl p-6 border border-green-200">
      <h3 class="font-semibold text-primary mb-3 flex items-center gap-2">
        <span class="text-green-700" aria-hidden="true">✓</span>
        {locale === 'sv' ? 'Skarpt idag' : 'Live today'}
      </h3>
      <ul class="space-y-2 text-sm text-gray-700">
        {t.mbotSecurity.statusToday.map((line) => (
          <li class="flex gap-2">
            <span class="text-green-700 shrink-0" aria-hidden="true">·</span>
            <span>{line}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="bg-white rounded-xl p-6 border border-gray-200">
      <h3 class="font-semibold text-primary mb-3 flex items-center gap-2">
        <span class="text-gray-500" aria-hidden="true">→</span>
        {locale === 'sv' ? 'På roadmap' : 'Roadmap'}
      </h3>
      <ul class="space-y-2 text-sm text-gray-700">
        {t.mbotSecurity.statusRoadmap.map((line) => (
          <li class="flex gap-2">
            <span class="text-gray-500 shrink-0" aria-hidden="true">·</span>
            <span>{line}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section class="bg-surface py-16">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-primary mb-4">{t.mbotSecurity.faqHeading}</h2>
    <p class="text-gray-600 leading-relaxed mb-8">{t.mbotSecurity.faqLead}</p>
    <ul class="space-y-3">
      {t.mbotSecurity.faq.map((entry, idx) => (
        <li>
          <details class="group bg-white rounded-xl border border-gray-100 [&[open]]:border-accent/30">
            <summary class="cursor-pointer px-5 py-4 font-semibold text-primary list-none flex items-start justify-between gap-4">
              <span>{entry.q}</span>
              <span class="text-accent shrink-0 transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-gray-700 leading-relaxed">
              {entry.a}
            </div>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="max-w-3xl mx-auto px-6 py-16 text-center">
  <h2 class="text-2xl font-bold text-primary mb-4">{t.mbotSecurity.contactHeading}</h2>
  <p class="text-gray-600 leading-relaxed mb-6 max-w-2xl mx-auto">{t.mbotSecurity.contactBody}</p>
  <a
    href={localizePath('/contact/', locale)}
    class="inline-block bg-primary hover:bg-primary-light text-white font-semibold px-8 py-3 rounded-lg transition-all hover:scale-105"
  >
    {t.mbotSecurity.contactCta}
  </a>
  <p class="text-xs text-gray-400 mt-8">{t.mbotSecurity.lastReviewed}</p>
</section>
