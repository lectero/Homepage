---
import Hero from '../Hero.astro';
import FeatureCard from '../FeatureCard.astro';
import { getStrings, type Locale } from '../../i18n/strings';
import { localizePath } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);

const products = [
  {
    icon: '📧',
    title: 'MBot',
    description: t.home.mbotDescription,
    href: localizePath('/products/mbot/', locale),
  },
  {
    icon: '🌱',
    title: 'GreenOps',
    description: t.home.greenopsDescription,
    href: '/products/greenops/',
  },
];
---

<Hero
  title={t.home.heroTitle}
  subtitle={t.home.heroSubtitle}
  cta={{ label: t.home.heroCta, href: localizePath('/products/mbot/', locale) }}
/>

<section class="max-w-6xl mx-auto px-6 py-20">
  <h2 class="text-3xl font-bold text-center text-primary mb-4">{t.home.productsHeading}</h2>
  <p class="text-center text-gray-600 max-w-2xl mx-auto mb-12">{t.home.productsLead}</p>
  <div class="grid md:grid-cols-2 gap-6">
    {products.map((product) => (
      <FeatureCard
        title={product.title}
        description={product.description}
        icon={product.icon}
        href={product.href}
      />
    ))}
  </div>
</section>

<section class="bg-surface py-20">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center text-primary mb-12">{t.home.whyHeading}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <FeatureCard title={t.home.whySwedish.title} description={t.home.whySwedish.text} icon="🇸🇪" />
      <FeatureCard title={t.home.whyTech.title} description={t.home.whyTech.text} icon="⚙️" />
      <FeatureCard
        title={t.home.whySustainability.title}
        description={t.home.whySustainability.text}
        icon="🌍"
      />
    </div>
  </div>
</section>

<section class="max-w-6xl mx-auto px-6 py-20 text-center">
  <h2 class="text-3xl font-bold text-primary mb-4">{t.home.ctaHeading}</h2>
  <p class="text-gray-600 max-w-xl mx-auto mb-8">{t.home.ctaText}</p>
  <a
    href={localizePath('/contact/', locale)}
    class="inline-block bg-primary hover:bg-primary-light text-white font-semibold px-8 py-3 rounded-lg transition-all hover:scale-105"
  >
    {t.home.ctaButton}
  </a>
</section>
