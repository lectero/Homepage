---
import { getCollection } from 'astro:content';
import { getStrings, type Locale } from '../i18n/strings';
import { localizePath } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
const year = new Date().getFullYear();

const publishedCases = await getCollection(
  'cases',
  ({ data }) => data.locale === locale && !data.draft
);
const casesPath = locale === 'sv' ? '/cases/' : '/en/cases/';
---

<footer class="bg-primary-dark text-gray-300">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a
          href={localizePath('/', locale)}
          class="text-white font-bold text-lg mb-3 block hover:text-accent transition-colors"
          >Lectero</a
        >
        <p class="text-sm leading-relaxed">{t.footer.tagline}</p>
      </div>

      <div>
        <h2 class="text-white font-semibold mb-3">{t.footer.products}</h2>
        <ul class="space-y-2 text-sm">
          <li><a href="/products/greenops/" class="hover:text-accent transition-colors">GreenOps</a></li>
          <li><a href={localizePath('/products/mbot/', locale)} class="hover:text-accent transition-colors">MBot</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-white font-semibold mb-3">{t.footer.contact}</h2>
        <ul class="space-y-2 text-sm">
          <li><a href={localizePath('/contact/', locale)} class="hover:text-accent transition-colors">{t.footer.contactUs}</a></li>
          <li><a href={localizePath('/about/', locale)} class="hover:text-accent transition-colors">{t.footer.aboutLectero}</a></li>
          {publishedCases.length > 0 && (
            <li><a href={casesPath} class="hover:text-accent transition-colors">{t.cases.title}</a></li>
          )}
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-gray-700 text-sm text-center">
      &copy; {year} Lectero. {t.footer.rightsReserved}
    </div>
  </div>
</footer>
