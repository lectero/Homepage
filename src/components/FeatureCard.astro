---
interface Props {
  title: string;
  description: string;
  icon?: string;
  iconImage?: { src: string; alt: string };
  href?: string;
}

const { title, description, icon, iconImage, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group block bg-white rounded-xl p-6 shadow-sm border border-gray-100 transition-all',
    href && 'hover:shadow-md hover:border-accent/30 hover:-translate-y-1',
  ]}
>
  {iconImage ? (
    <img src={iconImage.src} alt={iconImage.alt} width="48" height="48" class="mb-4 rounded-lg" />
  ) : (
    <div class="text-3xl mb-4" aria-hidden="true">{icon}</div>
  )}
  <h3 class="text-lg font-semibold text-primary mb-2 group-hover:text-accent transition-colors">
    {title}
  </h3>
  <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
</Tag>
