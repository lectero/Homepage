---
const navItems = [
  { label: 'Om oss', href: '/about/' },
  { label: 'Kontakt', href: '/contact/' },
];

const currentPath = Astro.url.pathname;

// Show product name instead of "Lectero" on product pages
const productBranding: Record<string, { name: string; href: string }> = {
  '/products/mbot/': { name: 'HMB Mailbot', href: '/products/mbot/' },
  '/products/greenops/': { name: 'GreenOps', href: '/products/greenops/' },
};

const matchedProduct = Object.entries(productBranding).find(([prefix]) =>
  currentPath.startsWith(prefix)
);
const brand = matchedProduct ? matchedProduct[1] : { name: 'Lectero', href: '/' };
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={brand.href} class="text-xl font-bold text-primary">
      {brand.name}
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navItems.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-accent',
              currentPath.startsWith(href) ? 'text-accent' : 'text-gray-600',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-600 hover:text-primary"
      aria-label="Meny"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <ul class="px-6 py-4 space-y-3">
      {navItems.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block text-sm font-medium transition-colors hover:text-accent',
              currentPath.startsWith(href) ? 'text-accent' : 'text-gray-600',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
