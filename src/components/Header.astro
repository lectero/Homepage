---
import { getStrings, type Locale } from '../i18n/strings';
import { localizePath, alternateLocale } from '../i18n/utils';

interface Props {
  locale: Locale;
  altPath: string;
}

const { locale, altPath } = Astro.props;
const t = getStrings(locale);

const navItems = [
  { label: t.nav.about, href: localizePath('/about/', locale) },
  { label: t.nav.news, href: '/blog/' },
  { label: t.nav.contact, href: localizePath('/contact/', locale) },
];

const currentPath = Astro.url.pathname;

const productBranding: Record<string, { name: string; href: string }> = {
  '/products/mbot/': { name: 'MBot', href: localizePath('/products/mbot/', locale) },
  '/en/products/mbot/': { name: 'MBot', href: '/en/products/mbot/' },
  '/products/greenops/': { name: 'GreenOps', href: '/products/greenops/' },
};

const matchedProduct = Object.entries(productBranding).find(([prefix]) =>
  currentPath.startsWith(prefix)
);
const brand = matchedProduct
  ? matchedProduct[1]
  : { name: 'Lectero', href: localizePath('/', locale) };

const otherLocale = alternateLocale(locale);
const switcherLabel =
  otherLocale === 'en' ? t.languageSwitcher.en : t.languageSwitcher.sv;
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between" aria-label={t.nav.products}>
    <a href={brand.href} class="text-xl font-bold text-primary">
      {brand.name}
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navItems.map(({ label, href }) => {
        const isActive = currentPath.startsWith(href) && href !== '/';
        return (
          <li>
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'text-sm font-medium transition-colors hover:text-accent',
                isActive ? 'text-accent' : 'text-gray-600',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
      <li>
        <a
          href={altPath}
          hreflang={otherLocale}
          aria-label={`${t.languageSwitcher.label}: ${switcherLabel}`}
          class="text-sm font-medium text-gray-500 hover:text-accent transition-colors uppercase tracking-wide"
        >
          {otherLocale}
        </a>
      </li>
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      type="button"
      data-open-label={t.nav.openMenu}
      data-close-label={t.nav.closeMenu}
      class="md:hidden p-2 text-gray-600 hover:text-primary focus:outline-2 focus:outline-accent rounded"
      aria-label={t.nav.openMenu}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <ul class="px-6 py-4 space-y-3">
      {navItems.map(({ label, href }) => {
        const isActive = currentPath.startsWith(href) && href !== '/';
        return (
          <li>
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'block text-sm font-medium transition-colors hover:text-accent',
                isActive ? 'text-accent' : 'text-gray-600',
              ]}
            >
              {label}
            </a>
          </li>
        );
      })}
      <li>
        <a
          href={altPath}
          hreflang={otherLocale}
          class="block text-sm font-medium text-gray-500 hover:text-accent transition-colors"
        >
          {switcherLabel}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute(
      'aria-label',
      isOpen ? btn.dataset.closeLabel ?? '' : btn.dataset.openLabel ?? ''
    );
  });
</script>
