---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TeamCard from '../components/TeamCard.astro';

const teamMembers = (await getCollection('team'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const approach = [
  {
    title: 'AI som arbetspartner, inte ersättare',
    text: 'Vi använder AI där det gör nytta — textgenerering, mönsterigenkänning, automation — men alltid med mänsklig kontroll och tydliga gränser. Samma princip bygger vi in i våra produkter: AI assisterar, människan beslutar.',
  },
  {
    title: 'Kontroll och transparens',
    text: 'Varje produkt vi bygger har spårbarhet, tydliga beslutslogiker och möjlighet att inspektera vad systemet gör och varför. Ingen svart låda.',
  },
  {
    title: 'Djup framför bredd',
    text: 'Vi fokuserar på specifika verksamhetsdomäner där vi förstår kontexten. Det gör att vi kan bygga lösningar som faktiskt passar — inte generiska plattformar som kräver veckor av anpassning.',
  },
];

const techCategories = [
  {
    label: 'Backend & API',
    items: ['Python', 'FastAPI', '.NET', 'Blazor'],
  },
  {
    label: 'AI & LLM',
    items: ['OpenAI', 'Anthropic Claude', 'RAG'],
  },
  {
    label: 'Integration',
    items: ['Microsoft Graph', 'Husqvarna Connect', 'SMHI'],
  },
  {
    label: 'Infrastruktur',
    items: ['PostgreSQL', 'SQLite', 'Docker', 'GitHub Actions'],
  },
];
---

<Base title="Om oss" description="Om Lectero — vilka vi är, hur vi jobbar och vad vi tror på">
  <Hero
    title="Om Lectero"
    subtitle="En liten, fokuserad verkstad som bygger digitala verktyg där korrekthet och spårbarhet är viktigare än maximal automation."
  />

  <!-- Story -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <div class="space-y-6">
      <p class="text-lg text-gray-700 leading-relaxed">
        Lectero är ett team av erfarna utvecklare som bestämde sig för att lösa verkliga problem hos verksamheter som ofta hamnar mellan stolarna — för stora för enmansverktyg, för små för enterprise-plattformar.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Vi bygger inte generiska SaaS-produkter. Vi bygger specifika lösningar för domäner vi förstår på djupet, med AI som arbetspartner och deterministiska regler där det gäller. Resultatet blir verktyg som är enkla att använda men ärliga om vad de gör — och inte gör.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Vår bakgrund spänner över akademisk forskning, industriell mjukvaruutveckling och agilt ledarskap. Det ger oss både det tekniska djupet och den praktiska ledarerfarenheten som krävs för att gå från idé till driftsatt system utan att tappa kvalitet på vägen.
      </p>
    </div>
  </section>

  <!-- Team -->
  <section class="bg-surface py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center text-primary mb-4">Teamet</h2>
      <p class="text-center text-gray-600 max-w-2xl mx-auto mb-12">
        Tre personer med olika bakgrunder men en gemensam övertygelse: bra mjukvara byggs av team som förstår både tekniken och verksamheten.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        {teamMembers.map((member) => (
          <TeamCard
            name={member.data.name}
            role={member.data.role}
            expertise={member.data.expertise}
            bio={member.data.bio}
            photo={member.data.photo}
            linkedinUrl={member.data.linkedinUrl}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="max-w-4xl mx-auto px-6 py-20">
    <h2 class="text-3xl font-bold text-primary mb-12 text-center">Så jobbar vi</h2>
    <div class="space-y-10">
      {approach.map((item) => (
        <div>
          <h3 class="text-xl font-semibold text-primary mb-3">{item.title}</h3>
          <p class="text-gray-600 leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Tech -->
  <section class="bg-surface py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-primary mb-4 text-center">Teknik vi arbetar med</h2>
      <p class="text-center text-gray-600 mb-12">
        Verktygen väljer vi från fall till fall — men dessa återkommer ofta.
      </p>
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-8">
        {techCategories.map((category) => (
          <div>
            <h4 class="text-sm font-semibold text-accent uppercase tracking-wide mb-3">
              {category.label}
            </h4>
            <div class="flex flex-wrap gap-2">
              {category.items.map((item) => (
                <span class="bg-white border border-gray-200 text-sm text-gray-700 rounded-full px-3 py-1">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-6 py-20 text-center">
    <h2 class="text-3xl font-bold text-primary mb-4">Låter det intressant?</h2>
    <p class="text-gray-600 max-w-xl mx-auto mb-8">
      Vi tar gärna en kopp kaffe och diskuterar hur vi kan hjälpa er verksamhet.
    </p>
    <a
      href="/contact/"
      class="inline-block bg-primary hover:bg-primary-light text-white font-semibold px-8 py-3 rounded-lg transition-all hover:scale-105"
    >
      Kontakta oss
    </a>
  </section>
</Base>
