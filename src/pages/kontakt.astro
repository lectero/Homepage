---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.tsx';
---

<Base title="Kontakt" description="Kontakta Lectero — vi vill gärna höra från dig">
  <Hero
    title="Kontakta oss"
    subtitle="Intresserad av våra produkter eller har frågor? Hör av dig så återkommer vi."
  />

  <section class="max-w-2xl mx-auto px-6 py-20">
    <ContactForm client:visible />
  </section>
</Base>
