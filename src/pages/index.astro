---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
---

<Base title="Hem">
  <Hero
    title="Digitala verktyg som driver förändring"
    subtitle="Lectero utvecklar system för hållbarhetsrapportering och intelligent automation — så att organisationer kan fokusera på det som räknas."
    cta={{ label: 'Utforska våra produkter', href: '/produkter/' }}
  />

  <!-- Products section -->
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h2 class="text-3xl font-bold text-center text-primary mb-4">Våra produkter</h2>
    <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">
      Vi bygger verktyg som löser verkliga problem — med fokus på användbarhet, tillförlitlighet och hållbarhet.
    </p>

    <div class="grid md:grid-cols-2 gap-8">
      <FeatureCard
        title="GreenOps"
        description="Hållbarhetsrapportering för organisationer. Samla in, beräkna och rapportera miljödata enligt etablerade ramverk — enkelt och transparent."
        icon="🌿"
        href="/produkter/greenops/"
      />
      <FeatureCard
        title="HMB Mailbot"
        description="AI-driven e-posthantering för svenska golfklubbar. Klassificerar, prioriterar och föreslår svar automatiskt — så att ingen fråga faller mellan stolarna."
        icon="🤖"
        href="/produkter/mbot/"
      />
    </div>
  </section>

  <!-- Why Lectero -->
  <section class="bg-surface py-20">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center text-primary mb-12">Varför Lectero?</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <FeatureCard
          title="Svenskt & nära"
          description="Vi förstår den svenska marknaden och bygger verktyg anpassade för nordiska organisationer och regelverk."
          icon="🇸🇪"
        />
        <FeatureCard
          title="Teknik som fungerar"
          description="Robusta system byggda med beprövad teknik. Vi prioriterar tillförlitlighet och säkerhet framför hype."
          icon="⚙️"
        />
        <FeatureCard
          title="Hållbarhet på riktigt"
          description="Från hållbarhetsrapportering till effektiv resursanvändning — hållbarhet genomsyrar allt vi gör."
          icon="🌍"
        />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <h2 class="text-3xl font-bold text-primary mb-4">Redo att komma igång?</h2>
    <p class="text-gray-600 max-w-xl mx-auto mb-8">
      Hör av dig så berättar vi mer om hur våra verktyg kan hjälpa din organisation.
    </p>
    <a
      href="/kontakt/"
      class="inline-block bg-primary hover:bg-primary-light text-white font-semibold px-8 py-3 rounded-lg transition-all hover:scale-105"
    >
      Kontakta oss
    </a>
  </section>
</Base>
