---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
---

<Base title="HMB Mailbot" description="HMB Mailbot — AI-driven e-posthantering för golfklubbar">
  <Hero
    title="HMB Mailbot"
    subtitle="AI som hjälper golfklubbar att hantera e-post snabbare och smartare."
    cta={{ label: 'Boka demo', href: '/kontakt' }}
  />

  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="space-y-16">
      <div>
        <h2 class="text-2xl font-bold text-primary mb-4">Vad är HMB Mailbot?</h2>
        <p class="text-gray-600 leading-relaxed">
          HMB Mailbot är en AI-driven e-postassistent byggd specifikt för svenska golfklubbar.
          Den läser inkommande e-post, klassificerar ärenden, bedömer prioritet och föreslår svar
          — så att kanslipersonal kan fokusera på det som kräver mänsklig bedömning.
        </p>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-primary mb-6">Hur det fungerar</h2>
        <div class="space-y-6">
          <div class="flex gap-4 items-start">
            <div class="bg-accent/10 text-accent font-bold rounded-full w-10 h-10 flex items-center justify-center shrink-0">1</div>
            <div>
              <h3 class="font-semibold text-primary">E-post tas emot</h3>
              <p class="text-sm text-gray-600">Mailboten övervakar inkorgarna och plockar upp nya meddelanden automatiskt.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="bg-accent/10 text-accent font-bold rounded-full w-10 h-10 flex items-center justify-center shrink-0">2</div>
            <div>
              <h3 class="font-semibold text-primary">Klassificering & prioritering</h3>
              <p class="text-sm text-gray-600">AI:n analyserar innehållet, kategoriserar ärendet och bedömer prioritet baserat på klubbens policy.</p>
            </div>
          </div>
          <div class="flex gap-4 items-start">
            <div class="bg-accent/10 text-accent font-bold rounded-full w-10 h-10 flex items-center justify-center shrink-0">3</div>
            <div>
              <h3 class="font-semibold text-primary">Svarsförslag</h3>
              <p class="text-sm text-gray-600">Ett kontextanpassat svarsförslag genereras som personalen kan granska, redigera och skicka.</p>
            </div>
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-primary mb-6">Fördelar</h2>
        <ul class="space-y-3 text-gray-600">
          <li class="flex gap-3"><span class="text-accent font-bold">&#10003;</span> Snabbare svarstider — inga ärenden faller mellan stolarna</li>
          <li class="flex gap-3"><span class="text-accent font-bold">&#10003;</span> Konsekvent kvalitet — svar baserade på klubbens policy och tonalitet</li>
          <li class="flex gap-3"><span class="text-accent font-bold">&#10003;</span> Mer tid för personalen — rutinärenden hanteras automatiskt</li>
          <li class="flex gap-3"><span class="text-accent font-bold">&#10003;</span> GDPR-säkert — all data hanteras enligt svenska regler</li>
        </ul>
      </div>
    </div>
  </section>
</Base>
