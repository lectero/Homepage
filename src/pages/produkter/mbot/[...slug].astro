---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('mbot');
  const allIds = new Set(entries.map((e) => e.id));

  return entries.map((entry) => {
    const slug = entry.id === 'index' ? undefined : entry.id.replace(/\/index$/, '');
    return {
      params: { slug },
      props: { entry, allIds },
    };
  });
}

const { entry, allIds } = Astro.props;
const { Content } = await render(entry);

const titleFromId = entry.id
  .split('/')
  .pop()
  ?.replace(/-/g, ' ')
  .replace(/^\w/, (c: string) => c.toUpperCase()) ?? 'HMB Mailbot';

// Build breadcrumb parts, only linking sections that have an index page
const parts = entry.id.split('/');
const breadcrumbs: { label: string; href?: string }[] = [];
if (entry.id !== 'index' && parts.length > 1) {
  const section = parts[0];
  const sectionLabel = section.replace(/-/g, ' ').replace(/^\w/, (c: string) => c.toUpperCase());
  const sectionIndexId = `${section}/index`;
  const sectionHasIndex = allIds.has(section) || allIds.has(sectionIndexId);
  breadcrumbs.push({
    label: sectionLabel,
    href: sectionHasIndex ? `/produkter/mbot/${section}/` : undefined,
  });
}
---

<Base title={`${titleFromId} — HMB Mailbot`} description="HMB Mailbot dokumentation">
  <div class="max-w-4xl mx-auto px-6 py-12">
    <!-- Breadcrumb navigation -->
    <nav class="mb-8 text-sm text-gray-500">
      <a href="/produkter/mbot/" class="hover:text-accent transition-colors">HMB Mailbot</a>
      {breadcrumbs.map((bc) => (
        <>
          <span class="mx-2">/</span>
          {bc.href ? (
            <a href={bc.href} class="hover:text-accent transition-colors">{bc.label}</a>
          ) : (
            <span>{bc.label}</span>
          )}
        </>
      ))}
    </nav>

    <!-- Content -->
    <article class="prose prose-lg max-w-none prose-headings:text-primary prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg prose-img:shadow-md">
      <Content />
    </article>

    <!-- Back navigation -->
    <div class="mt-12 pt-6 border-t border-gray-200">
      <a href="/produkter/mbot/" class="text-accent hover:underline text-sm">
        &larr; Tillbaka till HMB Mailbot
      </a>
    </div>
  </div>
</Base>
