---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('mbot');
  const allIds = new Set(entries.map((e) => e.id));

  // Exclude root index — handled by index.astro
  return entries
    .filter((entry) => entry.id !== 'index')
    .map((entry) => {
      const slug = entry.id.replace(/\/index$/, '');
      return {
        params: { slug },
        props: { entry, allIds },
      };
    });
}

const { entry, allIds } = Astro.props;
const { Content } = await render(entry);

const titleFromId = entry.id
  .split('/')
  .pop()
  ?.replace(/-/g, ' ')
  .replace(/^\w/, (c: string) => c.toUpperCase()) ?? 'HMB Mailbot';

// Build breadcrumb parts, only linking sections that have an index page
const parts = entry.id.split('/');
const breadcrumbs: { label: string; href?: string }[] = [];
if (entry.id !== 'index' && parts.length > 1) {
  const section = parts[0];
  const sectionLabel = section.replace(/-/g, ' ').replace(/^\w/, (c: string) => c.toUpperCase());
  const sectionIndexId = `${section}/index`;
  const sectionHasIndex = allIds.has(section) || allIds.has(sectionIndexId);
  breadcrumbs.push({
    label: sectionLabel,
    href: sectionHasIndex ? `/produkter/mbot/${section}/` : undefined,
  });
}
---

<Base title={`${titleFromId} — HMB Mailbot`} description="HMB Mailbot dokumentation">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <!-- Breadcrumb navigation -->
    <nav class="mb-8 flex items-center gap-2 text-sm">
      <a href="/produkter/mbot/" class="text-accent hover:underline font-medium transition-colors">HMB Mailbot</a>
      {breadcrumbs.map((bc) => (
        <>
          <span class="text-gray-400">/</span>
          {bc.href ? (
            <a href={bc.href} class="text-accent hover:underline font-medium transition-colors">{bc.label}</a>
          ) : (
            <span class="text-gray-600 font-medium">{bc.label}</span>
          )}
        </>
      ))}
    </nav>

    <!-- Content -->
    <article class="prose prose-lg max-w-none prose-headings:text-primary prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg prose-img:shadow-md">
      <Content />
    </article>

    <!-- Back navigation -->
    <div class="mt-16 pt-6 border-t border-gray-200">
      <a href="/produkter/mbot/" class="inline-flex items-center gap-1 text-accent hover:underline text-sm font-medium transition-colors">
        &larr; Tillbaka till HMB Mailbot
      </a>
    </div>
  </div>
</Base>
