---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const dateFormatter = new Intl.DateTimeFormat('sv-SE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title="Nyheter" description="Lectero — nyheter, releaser och uppdateringar från MBot och GreenOps">
  <Hero
    title="Nyheter"
    subtitle="Releaser, produktuppdateringar och tankar från Lectero-teamet."
  />

  <section class="max-w-3xl mx-auto px-6 py-16">
    {posts.length === 0 ? (
      <p class="text-gray-600 text-center">Inga inlägg publicerade ännu.</p>
    ) : (
      <ol class="space-y-8">
        {posts.map((post) => (
          <li class="border-b border-gray-100 pb-8 last:border-0">
            <article>
              <p class="text-sm text-gray-500 mb-2">
                <time datetime={post.data.date.toISOString()}>
                  {dateFormatter.format(post.data.date)}
                </time>
              </p>
              <h2 class="text-2xl font-bold text-primary mb-3">
                <a href={`/blog/${post.id}/`} class="hover:text-accent transition-colors">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-gray-600 leading-relaxed mb-3">{post.data.summary}</p>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag) => (
                    <span class="bg-surface text-xs font-medium text-gray-700 rounded-full px-2.5 py-1">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </article>
          </li>
        ))}
      </ol>
    )}

    <p class="text-sm text-gray-500 mt-12 text-center">
      <a href="/rss.xml" class="hover:text-accent transition-colors">Prenumerera via RSS</a>
    </p>
  </section>
</Base>
